ENV=production
LOG_LEVEL=INFO

BASE_WEBHOOK_URL=https://bots.example.com
WEBHOOK_SECRET=change-me-to-a-long-random-string
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

ADMIN_TG_ID=123456789
ADMIN_BOT_TOKEN=111111:AAAA-admin-bot-token

POSTGRES_DSN=postgresql+asyncpg://bots:bots@postgres:5432/bots
REDIS_DSN=redis://redis:6379/0

SUBSCRIPTION_CHECK_CACHE_TTL=30
BROADCAST_MESSAGES_PER_SECOND=25
